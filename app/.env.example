# ── Supabase (Dashboard → Settings → API) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here   # server-only, never expose to browser

# ── App URL ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # change to https://your-app.vercel.app in prod

# ── Email — Resend free tier (3,000 emails/month) ─────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# ── Cron security ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-long-random-string
